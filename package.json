{
  "name": "vscode-extension-flat-ui-color-picker",
  "displayName": "Flat UI Color Picker",
  "description": "Browse, filter by shade, and copy Flat UI color codes in HEX, RGB, HSL, and CMYK formats",
  "version": "1.0.0",
  "publisher": "SuryaPrakashPandurangi",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "colors",
    "flat ui",
    "color picker",
    "palette",
    "design"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/local-dev/vscode-extension-flat-ui-color-picker"
  },
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "flatUiColors.open",
        "title": "Flat UI Colors: Open Color Browser",
        "icon": "$(symbol-color)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.4"
  }
}
